# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-random-256-bit-string

# ── Database ──────────────────────────────────────
# SQLite (dev/local — no setup needed)
DB_PATH=./hamro_khata.db

# PostgreSQL (production — comment out DB_PATH above and uncomment this)
# DATABASE_URL=postgresql://hamrokhata:password@localhost:5432/hamrokhata_prod

# ── Redis (optional — for rate limiting & caching) ──
# REDIS_URL=redis://localhost:6379

# ── File Storage (Cloudflare R2 / AWS S3) ─────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=hamrokhata-files
# R2_PUBLIC_URL=https://files.hamrokhata.app

# ── SMS Gateway (Nepal) ───────────────────────────
# SPARROW_SMS_TOKEN=
# SPARROW_SMS_FROM=HamroKhata

# ── WhatsApp Business API (optional) ──────────────
# WA_BUSINESS_PHONE_ID=
# WA_ACCESS_TOKEN=

# ── App URLs ──────────────────────────────────────
API_BASE_URL=http://localhost:3001
CORS_ORIGIN=*
