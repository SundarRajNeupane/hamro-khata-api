{
  "name": "hamro-khata-api",
  "version": "1.0.0",
  "description": "Backend API for Hamro Khata — Digital Ledger for Nepal SMBs",
  "main": "HamroKhata_Backend.js",
  "scripts": {
    "start":   "node HamroKhata_Backend.js",
    "dev":     "nodemon HamroKhata_Backend.js",
    "test":    "jest --coverage",
    "lint":    "eslint .",
    "db:init": "node -e \"require('./HamroKhata_Backend.js')\" && echo 'DB initialised'"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs":        "^2.4.3",
    "pg":  "^8.11.0",
    "cors":            "^2.8.5",
    "dotenv":          "^16.4.5",
    "express":         "^4.18.3",
    "jsonwebtoken":    "^9.0.2",
    "uuid":            "^9.0.1"
  },
  "devDependencies": {
    "eslint":          "^8.57.0",
    "jest":            "^29.7.0",
    "nodemon":         "^3.1.0",
    "supertest":       "^6.3.4"
  },
  "keywords": ["nepal", "ledger", "khata", "fintech", "offline-first", "sme"],
  "license": "MIT"
}
